# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# SMTP Configuration (for email notifications)
# TransIP SMTP settings
SMTP_HOST=mail.transip.nl
SMTP_PORT=587
SMTP_USER=your-email@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@fileninja.com

# TransIP SMTP Configuration Notes:
# - Use your TransIP hosting account email credentials
# - Port 587 is recommended for TLS/STARTTLS (secure: false)
# - Port 465 can be used for SSL (secure: true)
# - Make sure your domain is properly configured with TransIP
# - The SMTP_FROM should be an email address on your domain
