# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# SMTP Configuration (for sending emails)
SMTP_HOST=smtp.transip.email
SMTP_PORT=465
SMTP_USER=your-email@yourdomain.com
SMTP_PASS=your-email-password
SMTP_FROM=your-email@yourdomain.com

# OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_SECRET_ID=your-google-secret-id
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_SECRET_ID=your-github-secret-id

# Mailchimp Configuration (for newsletter subscriptions)
MAILCHIMP_API_KEY=your-mailchimp-api-key
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_AUDIENCE_ID=your-mailchimp-audience-id

# File Upload Configuration
MAX_FILE_SIZE=3221225472
UPLOAD_DIR=uploads
