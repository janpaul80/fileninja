# ──────────────────────────────────────────────────────────────
# Fileninja — environment variables
# Copy this file to `.env.local` and fill in your real keys.
# .env.local is gitignored.
# ──────────────────────────────────────────────────────────────

# Public site URL (used for SEO, OpenGraph, Stripe redirects, email links)
NEXT_PUBLIC_SITE_URL=https://fileninja.cloud

# ─── Supabase ─────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Stripe ───────────────────────────────────────────────────
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (one per plan/interval)
NEXT_PUBLIC_STRIPE_PRICE_BASIC_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_BASIC_YEARLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=price_...

# ─── File storage (pick one) ──────────────────────────────────
# Option A: Supabase Storage (simplest — uses keys above)
SUPABASE_STORAGE_BUCKET=fileninja-transfers

# Option B: Cloudflare R2 / AWS S3
# S3_ENDPOINT=https://YOUR-ACCOUNT.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_BUCKET=fileninja-transfers

# ─── Email (transactional — share-link delivery) ──────────────
# Resend (recommended) — https://resend.com
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="Fileninja <send@fileninja.cloud>"

# ─── Optional: Virus scanning ─────────────────────────────────
# CLOUDMERSIVE_API_KEY=...

# ─── Optional: Analytics ──────────────────────────────────────
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=fileninja.cloud
